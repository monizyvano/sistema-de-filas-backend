# ============================================
# CONFIGURAÇÕES DO SISTEMA FILAS IMTSB
# ============================================
# Copie este arquivo para .env e preencha os valores

# ============================================
# AMBIENTE
# ============================================
FLASK_ENV=development
# Opções: development, testing, production

FLASK_DEBUG=1
# 1 = Debug ON, 0 = Debug OFF

# ============================================
# SEGURANÇA (IMPORTANTE!)
# ============================================
SECRET_KEY=bf5ced407509456ded3e88d7eebb352696d70cf1b7fc75a2fe1449d862ff2ff7
# ⚠️ MUDE EM PRODUÇÃO! Gere com: python -c "import secrets; print(secrets.token_hex(32))"

JWT_SECRET_KEY=47e67b4a69e90ee44afe69442eba62e7e81a00cbca49e0dacaf316d5a90ce2f1
# ⚠️ MUDE EM PRODUÇÃO! Gere com: python -c "import secrets; print(secrets.token_hex(32))"

# ============================================
# BANCO DE DADOS MySQL
# ============================================
DB_NAME=sistema_filas_imtsb
DB_USER=root
DB_PASSWORD=Yasminey13
DB_HOST=localhost
DB_PORT=3306

# ============================================
# UPLOAD DE ARQUIVOS
# ============================================
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216
# 16MB em bytes (16 * 1024 * 1024)

# ============================================
# CORS (Origens Permitidas)
# ============================================
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# ============================================
# JWT (Tokens)
# ============================================
JWT_ACCESS_TOKEN_EXPIRES=28800
# 8 horas em segundos (8 * 60 * 60)

JWT_REFRESH_TOKEN_EXPIRES=604800
# 7 dias em segundos (7 * 24 * 60 * 60)

# ============================================
# NOTIFICAÇÕES (Opcional - Futuro)
# ============================================
# SMS_API_KEY=your-sms-api-key
# SMS_API_URL=https://api.sms-provider.com

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
# Opções: DEBUG, INFO, WARNING, ERROR, CRITICAL

LOG_TO_FILE=1
# 1 = Salvar logs em arquivo, 0 = Apenas console

# ============================================
# CACHE (Opcional)
# ============================================
CACHE_TYPE=simple
# Opções: simple, redis

# REDIS_URL=redis://localhost:6379/0
# Descomentar se usar Redis

# ============================================
# PRODUÇÃO (Apenas em servidor)
# ============================================
# SERVIDOR_URL=https://filas.imtsb.ao
# ENABLE_HTTPS=1
# FORCE_HTTPS=1